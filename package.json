{
  "name": "market-bay",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --bun --watch run server/dev.ts",
    "build": "NODE_ENV=production bun run build:frontend && bun run build:server",
    "build:frontend": "bun --bun vite build",
    "build:server": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile dist/app server/prod.ts",
    "dev-vite": "bun --bun vite dev",
    "start": "NODE_ENV=production ./dist/app",
    "format": "biome format",
    "lint": "biome lint",
    "email": "email dev --dir src/server/emails",
    "check": "biome check",
    "check:ci": "biome ci",
    "type:check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/server/database/seeds.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@kobalte/core": "^0.13.11",
    "@rasla/logify": "^5.2.1",
    "@react-email/components": "^1.0.10",
    "@t3-oss/env-core": "^0.13.8",
    "@tanstack/solid-form": "^1.28.4",
    "@tanstack/solid-query": "^5.90.26",
    "@tanstack/solid-router": "^1.163.2",
    "@tanstack/solid-router-devtools": "^1.163.2",
    "@tanstack/solid-router-ssr-query": "^1.166.7",
    "@tanstack/solid-start": "^1.163.2",
    "@valibot/to-json-schema": "^1.5.0",
    "bentocache": "^1.6.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.0",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.27",
    "elysia-healthcheck": "^1.0.0",
    "elysiajs-helmet": "^1.0.4",
    "inflection": "^3.0.2",
    "ioredis": "^5.9.3",
    "logixlysia": "^6.2.0",
    "lucide-solid": "^0.575.0",
    "mailchecker": "^6.0.19",
    "modern-csrf": "^0.0.3",
    "ms": "^2.1.3",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-email": "^5.2.10",
    "resend": "^6.9.2",
    "solid-js": "^1.9.10",
    "sqids": "^0.3.0",
    "typebox": "^1.1.6",
    "valibot": "^1.2.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/solid-query-devtools": "^5.95.0",
    "@types/bun": "^1.3.0",
    "@types/ms": "^2.1.0",
    "@types/react": "^19.2.14",
    "@types/validator": "^13.15.10",
    "bun-types": "latest",
    "dotenv": "^16.0.0",
    "drizzle-kit": "^0.31.8",
    "elysia-connect-middleware": "^0.0.6",
    "pg": "^8.19.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
