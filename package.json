{
  "name": "market-bay",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "check:ci": "biome ci",

    "type:check": "bun --filter '*' type:check",
    "test": "bun --filter '*' test",

    "lint:fix:all": "bun --filter '*' lint:fix",
    "lint:check": "bun --filter '*' lint:check",
    "format:fix": "prettier --write",
    "format:fix:all": "prettier --write \"**/*.(ts|tsx)\"",
    "format:check": "prettier --check \"**/*.(ts|tsx)\"",
    "verify": "bun run type:check && bun run lint:check && bun run format:check && bun --filter '*' circular"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@tanstack/solid-form": "^1.28.4",
    "@tanstack/solid-router": "^1.163.2",
    "@tanstack/solid-router-devtools": "^1.163.2",
    "@tanstack/solid-start": "^1.163.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "inflection": "^3.0.2",
    "lucide-solid": "^0.575.0",
    "ms": "^2.1.3",
    "pino": "^10.3.1",
    "solid-js": "^1.9.10",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.0",
    "@types/ms": "^2.1.0",
    "bun-types": "latest",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
